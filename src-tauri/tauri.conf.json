{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Keepix by KOU",
  "version": "4.0.1",
  "identifier": "com.keepix.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Keepix — Photo & Video Culling",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "licenseFile": "../static/LICENSE.txt",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "headerImage": "icons/nsis-header.bmp",
        "installMode": "both",
        "displayLanguageSelector": true,
        "languages": ["English", "Indonesian"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk0MjhFODg4MzcyMzNFMzUKUldRMVBpTTNpT2dvbEN4VXlMRjVrYWRSVjhrUlprcG9ncDdKSmYwZDBxUlR0Wk1WYmt5bjhTLzEK",
      "endpoints": [
        "https://example.com/update/{{target}}/{{current_version}}"
      ],
      "dialog": true
    }
  }
}
